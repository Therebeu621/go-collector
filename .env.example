# --- Required ---
DATABASE_URL=postgres://collector:collector@localhost:5434/collector?sslmode=disable

# --- Optional (with defaults) ---
LIMIT=30
PAGE_SIZE=30
WORKERS=4
RATE_LIMIT=5
REQUEST_TIMEOUT=10s
LOG_LEVEL=info
LOG_FORMAT=json
# LOG_FORMAT=pretty  # for local dev

# API_BASE_URL=https://dummyjson.com/products

# --- Proxy (standard Go env vars) ---
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
# NO_PROXY=localhost,127.0.0.1

# --- Metrics ---
# METRICS_ADDR=:9090

# --- Grafana (docker-compose observability stack) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# --- Optional Analytics Sink (ClickHouse over HTTP) ---
# CLICKHOUSE_DSN=http://collector:collector@localhost:8123/default
